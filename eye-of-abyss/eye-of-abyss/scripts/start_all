#!/bin/bash

# List of alt account names (match your .service files)
declare -a accounts=(
  "abyss_alt1" "abyss_alt2" "abyss_alt3" "abyss_alt4" "shunsy" "hybrol" "sassydoll" "kwishee"
  #"barth" "_theorangejuice_" "rafiman" 
  #"cash_master" "king_eazy87" "pizzaking106" "icedcoffeelol" 
)


# Restart each service
for i in "${accounts[@]}"
do
  echo "🔄 Restarting: eye-of-abyss-$i.service"
  sudo systemctl restart eye-of-abyss-$i.service
  sleep 3
done

echo ""
echo "📺 Starting live logs for all services..."
sleep 2

# Follow all logs
journalctl -fu 'eye-of-abyss-*'

# cd ~/eye-of-abyss
